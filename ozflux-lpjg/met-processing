class DatasetType(enum.IntEnum):
    OZFLUX = 0,
    AMERIFLUX = 1

class Options:
    """
    Class for storing CLI arguments from the user.

    @param log: Log level.
    @param files: Input files.
    @param odir: Output directory.
    @param prog: True to write progress messages, 0 otherwise.
    @param parallel: True to process files in parallel.
    @param timestep: Desired output timestep, in minutes.
    @param compression_level: Compression quality for output file [0, 9]. 0 = none, 1 = fastest compression, largest filesize, 9 = slowest compression, smallest filesize.
    @param compression_type: Compression algorithm to be used (default 'zlib').
    @param dataset_type: Type of dataset (OZFLUX or AMERIFLUX).
    """
    def __init__(self, log : LogLevel, files: list[str], odir: str, prog: bool,
                 parallel: bool, timestep: int, compression_level: int,
                 compression_type: str, dataset_type: DatasetType):
        self.log_level = log
        self.files = files
        self.out_dir = odir
        self.report_progress = prog
        self.parallel = parallel
        self.timestep = timestep
        self.compression_level = compression_level
        self.compression_type = compression_type
        self.dataset_type = dataset_type

class MetProcessingTask(ozflux_parallel.Task):
    def __init__(self, infile: str, outfile: str, timestep: int,
                 compression_level: int, compression_type: str,
                 dataset_type: DatasetType):
        self.infile = infile
        self.outfile = outfile
        self.timestep = timestep
        self.compression_level = compression_level
        self.compression_type = compression_type
        self.dataset_type = dataset_type

    def exec(self, pcb: Callable[[float], None]):
        try:
            process_file(self.infile, self.outfile, self.timestep,
                         self.compression_level, self.compression_type,
                         self.dataset_type, pcb)
        except BaseException as err:
            raise ValueError(f"Failed to process {self.infile}") from err

def get_vars(timestep: int, dataset_type: DatasetType) -> list[ForcingVariable]:
    """
    Get the list of variables to be copied to the output file.

    @param timestep: Output timestep in minutes.
    @param dataset_type: Type of dataset (OZFLUX or AMERIFLUX).
    """
    if (dataset_type == DatasetType.AMERIFLUX):
        return get_ameriflux_vars(timestep)
    return get_ozflux_vars(timestep)

def copy_data(nc_in: Dataset, nc_out: Dataset, plan: TimePlan,
              vars: list[ForcingVariable], pcb: Callable[[float], None]):
    """
    Copy data to the output file in dailygrass format.

    @param nc_in: Input NetCDF file.
    @param nc_out: Output NetCDF file.
    @param plan: Time plan for output data.
    @param vars: List of variables to be copied.
    @param pcb: Progress callback function.
    """
    i = 0

    global global_read_prop, global_write_prop
    read_prop = global_read_prop
    write_prop = global_write_prop

    nvar = len(vars)

    n = 0
    for var in vars:
        log_diagnostic("----- %s -----" % var.in_name)
        log_diagnostic("Reading %s data" % var.in_name)

        reporter = lambda p: pcb( (i + p * read_prop) / nvar)
        read_start = time.time()
        data = get_data(nc_in, var, plan, False, True, reporter)
        read_time = time.time() - read_start

        n = max(n, len(data))

        log_diagnostic("Writing %s data" % var.in_name)
        reporter = lambda p: pcb( (i + read_prop + write_prop * p) / nvar)
        write_start = time.time()
        var_out = nc_out.variables[var.out_name]
        var_out[:] = numpy.reshape(data, var_out.shape)
        write_time = time.time() - write_start

        # Bookkeeping.
        total_time = read_time + write_time
        read_prop = read_time / total_time
        write_prop = write_time / total_time
        log_debug(f"read_prop={read_prop:.2f}")
        log_debug(f"write_prop={write_prop:.2f}")

        i += 1

def create_dimensions(nc: Dataset, ngridcell: int):
    """
    Create the required dimensions in the output file.
    """
    log_debug("Creating output dimensions")

    dim_size = 0 if UNLIMITED_DIMS else ngridcell
    create_dim_if_not_exists(nc, DIM_LON, dim_size)
    create_dim_if_not_exists(nc, DIM_LAT, dim_size)

    # Create time dimension with unlimited size.
    create_dim_if_not_exists(nc, DIM_TIME)

def create_variables(nc: Dataset, timestep: int, clevel: int, ctype: str,
                     vars: list[ForcingVariable]):
    """
    Create the required variables in the output file.

    @param nc: The output .nc file.
    @param version: The lpj-guses version selected by the user.
    @param timestep: Output timestep in minutes.
    @param clevel: Compression level [1-9], 9 = slowest/smallest.
    @param ctype: Compression algorithm to be used (or None).
    @param vars: List of variables to be created in the output file.
    """
    log_debug("Creating output variables")
    format = FORMAT_FLOAT

    geo_chunk_size = (1,)
    create_var_with_metadata(nc, DIM_LON, format, DIM_LON, STD_LON,
                               LONG_LON, UNITS_LON, chunksizes = geo_chunk_size)
    create_var_with_metadata(nc, DIM_LAT, format, DIM_LAT, STD_LAT,
                               LONG_LAT, UNITS_LAT, chunksizes = geo_chunk_size)

    time_chunksize = get_steps_per_year(timestep)
    time_chunks = (time_chunksize,)
    time_units = f"hours since {DATE_BASELINE}"
    create_var_with_metadata(nc, DIM_TIME, format, DIM_TIME, STD_TIME,
                             LONG_TIME, time_units, clevel, ctype, time_chunks)
    nc.variables[DIM_TIME].calendar = CALENDAR_GREGORIAN

    # TODO: configurable dimension order (achieved via constants)
    dims = (DIM_LAT, DIM_LON, DIM_TIME)
    chunksizes = (1, 1, time_chunksize)
    for var in vars:
        # TODO: we should set standard_name and long_name here too, rather than
        # relying on them to exist in the input files.
        # TODO: variable detection should have multiple options:
        # 1. Look for user-specified names supplied via CLI
        # 2. Detect variables in input files based on standard_name
        create_var_if_not_exists(nc, var.out_name, format, dims, clevel, ctype,
                                 chunksizes)
        out_var = nc.variables[var.out_name]
        setattr(out_var, ATTR_UNITS, var.out_units)
        setattr(out_var, ATTR_STD_NAME, var.std_name)

def populate_coord_vars(nc: Dataset, lats: numpy.ndarray, lons: numpy.ndarray,
                        plan: TimePlan):
    """
    Populate the coordinate variables in the output file.

    @param nc: The output .nc file.
    @param lats: Array of latitude values.
    @param lons: Array of longitude values.
    @param plan: Time plan for the output file.
    """
    log_diagnostic("Populating coordinate variables...")
    lon = nc.variables[DIM_LON]
    lat = nc.variables[DIM_LAT]
    time = nc.variables[DIM_TIME]

    lon[:] = lons
    lat[:] = lats
    time[:] = date2num(plan.output_time_values, time.units, time.calendar)

def prepare_outfile(nc: Dataset, lats: numpy.ndarray, lons: numpy.ndarray,
                    plan: TimePlan, clevel: int, ctype: str,
                    vars: list[ForcingVariable]):
    """
    Create the variables in the output NetCDF file. The variables created
    will depend to some degree on the output type.

    @param nc: Output .nc file.
    @param lats: Array of latitude values.
    @param lons: Array of longitude values.
    @param plan: Time plan for the output file.
    @param clevel: Compression level [1-9], 9 = slowest/smallest.
    @param ctype: Compression algorithm to be used (or None).
    @param vars: List of variables to be created in the output file.
    """
    create_dimensions(nc, len(lats))
    create_variables(nc, plan.policy.output_timestep_minutes, clevel, ctype,
                     vars)
    populate_coord_vars(nc, lats, lons, plan)

def write_metadata(nc: Dataset, timestep: int):
    """
    Write version-specific metadata.

    @param nc: Output .nc file.
    @param timestep: Output timestep in minutes.
    @param version: Output version selected by the user.
    """
    ozflux_netcdf.write_common_metadata(nc, timestep)

def process_dataset(nc_in: Dataset, nc_out: Dataset, plan: TimePlan, clevel: int,
                    ctype: str, dataset_type: DatasetType, pcb: Callable[[float], None]):
    """
    Process the given input dataset and write to the output dataset.

    @param nc_in: Input .nc file.
    @param nc_out: Output .nc file.
    @param plan: Time plan for the output file.
    @param clevel: Compression level [1-9], 9 = slowest/smallest.
    @param ctype: Compression algorithm to be used (or None).
    @param dataset_type: Type of dataset (OZFLUX or AMERIFLUX).
    @param pcb: Progress callback function.
    """
    lats = nc_in.variables[DIM_LAT][:]
    lons = nc_in.variables[DIM_LON][:]
    if len(lats) != len(lons):
        raise ValueError(f"Input file has different number of latitudes ({len(lats)}) and longitudes ({len(lons)})")

    vars = get_vars(plan.policy.output_timestep_minutes, dataset_type)

    # We could also verify that the file only contains a single
    # gridcell, but later code verifies this anyway.
    log_diagnostic(f"Initialising output file...")
    prepare_outfile(nc_out, lats, lons, plan, clevel, ctype, vars)

    # Copy data into this variable.
    log_diagnostic("Copying data")
    copy_data(nc_in, nc_out, plan, vars, pcb)

    # Write additional global/common metadata.
    log_diagnostic("Writing additional metadata")
    write_metadata(nc_out, plan.policy.output_timestep_minutes)

def process_file(in_file: str, out_file: str, timestep: int, clevel: int,
                 ctype: str, dataset_type: DatasetType,
                 pcb: Callable[[float], None]):
    """
    Read the input file and generate an output file at the specified
    path in LPJ-GUESS-DAVE format.

    @param in_file: Input file path.
    @param out_file: Output file path.
    @param timestep: Output timestep length in minutes.
    @param clevel: Compression level [1-9], 9 = slowest/smallest.
    @param ctype: Compression algorithm to be used (or None).
    @param dataset_type: Type of dataset (OZFLUX or AMERIFLUX).
    @param pcb: Progress callback function.
    """
    log_information(f"Processing {in_file}...")
    policy = TimePolicy(output_timestep_minutes = timestep)
    with open_netcdf(out_file, True) as nc_out:
        with open_netcdf(in_file) as nc_in:
            # Quick sanity check of time step.
            plan = make_time_plan(nc_in, policy)
            validate_time_plan(plan)
            process_dataset(nc_in, nc_out, plan, clevel, ctype, dataset_type, pcb)

def parse_args(argv: list[str]) -> Options:
    """
    Parse CLI arguments, return a parsed options object.

    @param argv: Raw CLI arguments.

    @return Parsed Options object.
    """
    parser = ArgumentParser(prog=argv[0], description = "Formatting ozflux data into a format suitable for consumption by LPJ-Guess")
    parser.add_argument("-v", "--verbosity", type = int, help = "Logging verbosity (1-5, default 3)", nargs = "?", const = LogLevel.INFORMATION, default = LogLevel.INFORMATION)
    parser.add_argument("files", nargs = "+", help = "Input .nc files to be processed")
    parser.add_argument("-o", "--out-dir", required = True, help = "Path to the output directory. Processed files will be saved with the same file name into this directory")
    parser.add_argument("-p", "--show-progress", action = "store_true", help = "Report progress")
    parser.add_argument("-P", "--parallel", action = "store_true", help = "Process files in parallel")
    parser.add_argument("-t", "--timestep", type = int, required = True, help = "Output timestep in minutes")
    parser.add_argument("--compression-level", type = int, nargs = "?", default = 4, help = "Compression quality for output file [0, 9]. 0 = none, 1 = fastest compression, largest filesize, 9 = slowest compression, smallest filesize (default 4)")
    parser.add_argument("--compression-type", default = "zlib", help = "Compression algorithm to be used (default 'zlib')")
    parser.add_argument("-a", "--ameriflux", action = "store_true", help = "Treat input files as ameriflux files (e.g. for checking variable names).")
    parser.add_argument("--version", action = "version", version = "%(prog)s " + VERSION)

    parsed = parser.parse_args(argv[1:])
    dataset_type = DatasetType.AMERIFLUX if parsed.ameriflux else DatasetType.OZFLUX
    return Options(parsed.verbosity, parsed.files, parsed.out_dir,
                   parsed.show_progress, parsed.parallel, parsed.timestep,
                   parsed.compression_level, parsed.compression_type,
                   dataset_type)

# @profile
def main(opts: Options):
    """
    Main CLI entrypoint function.

    @param opts: Object containing parsed CLI arguments.
    """
    # Create output directory if it doesn't exist.
    if not os.path.exists(opts.out_dir):
        os.makedirs(opts.out_dir)

    job_manager = ozflux_parallel.JobManager()

    for infile in opts.files:
        out_file_name = os.path.basename(infile)

        outfile = os.path.join(opts.out_dir, out_file_name)
        if os.path.exists(outfile):
            os.remove(outfile)

        job = MetProcessingTask(infile, outfile, opts.timestep,
                                opts.compression_level, opts.compression_type,
                                opts.dataset_type)

        job_manager.add_job(job, os.path.getsize(infile))

    if opts.parallel:
        job_manager.run_parallel()
    else:
        job_manager.run_single_threaded()

if __name__ == "__main__":
    # Parse CLI args
    opts = parse_args(argv)

    set_log_level(opts.log_level)
    set_show_progress(opts.report_progress)

    try:
        # Actual logic is in main().
        main(opts)
    except BaseException as error:
        # Basic error handling.
        log_error(format_exc())
        exit(1)
